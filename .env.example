# ============================================================
# RankForge CLI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# All keys are optional — the tool gracefully degrades without them.
# ============================================================

# ── AI Provider API Keys ─────────────────────────────────────
# Get your keys from the respective provider dashboards.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Default AI Provider ──────────────────────────────────────
# Options: openai, claude, gemini
DEFAULT_AI_PROVIDER=claude
DEFAULT_AI_MODEL_OPENAI=gpt-4o
DEFAULT_AI_MODEL_CLAUDE=claude-sonnet-4-20250514
DEFAULT_AI_MODEL_GEMINI=gemini-2.0-flash

# ── SEO API Keys ────────────────────────────────────────────
# SerpAPI: https://serpapi.com (free tier available)
SERPAPI_KEY=

# DataForSEO: https://dataforseo.com (for backlink data)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_BURST=5

# ── Cache ───────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_DIR=.rankforge_cache

# ── Storage ─────────────────────────────────────────────────
DATA_DIR=.rankforge_data
EXPORT_DIR=exports

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=rankforge.log

# ── Scraping ────────────────────────────────────────────────
SCRAPER_TIMEOUT=15
SCRAPER_MAX_RETRIES=3
